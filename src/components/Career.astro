---
import { career } from '../data/resume';
---

<section class="section">
  <h2 class="section-header">Career</h2>
  {career.map((job) => (
    <div class="job-row">
      <div>
        <span>{job.role}, </span>
        {job.url ? (
          <a href={job.url} target="_blank" rel="noopener noreferrer">
            {job.company} ↗
          </a>
        ) : (
          <span>{job.company}</span>
        )}
      </div>
      <span class="dates muted">
        {job.start}{job.end ? ` – ${job.end}` : ' –'}
      </span>
    </div>
  ))}
</section>

<style>
  .job-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.3rem 0;
    gap: 1rem;
  }
  .dates {
    font-size: 0.8rem;
    white-space: nowrap;
  }
</style>
