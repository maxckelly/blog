---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | Max Kelly`} description={post.data.description}>
  <nav>
    <a href="/">← Back</a>
  </nav>
  <article>
    <header>
      <time class="muted" datetime={post.data.date.toISOString()}>
        {post.data.date.toLocaleDateString('en-US', {
          month: 'long',
          day: 'numeric',
          year: 'numeric',
        })}
      </time>
      <h1>{post.data.title}</h1>
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  nav {
    margin-bottom: 3rem;
  }
  nav a {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  nav a:hover {
    color: var(--text);
  }
  article header {
    margin-bottom: 2.5rem;
  }
  article header time {
    font-size: 0.8rem;
  }
  article header h1 {
    font-size: 1.6rem;
    margin-top: 0.5rem;
    line-height: 1.3;
  }
  .prose :global(p) {
    margin-bottom: 1.25rem;
  }
  .prose :global(h2) {
    font-size: 1.2rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose :global(h3) {
    font-size: 1rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose :global(code) {
    background: #1a1a1a;
    padding: 0.15rem 0.35rem;
    border-radius: 3px;
    font-size: 0.9em;
  }
  .prose :global(pre) {
    background: #1a1a1a;
    padding: 1rem;
    border-radius: 4px;
    overflow-x: auto;
    margin-bottom: 1.25rem;
  }
  .prose :global(pre code) {
    background: none;
    padding: 0;
  }
  .prose :global(a) {
    color: var(--link);
    border-bottom: 1px solid var(--text-muted);
  }
  .prose :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding-left: 1rem;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }
  .prose :global(ul), .prose :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.25rem;
  }
</style>
